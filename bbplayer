def supports_unicode():
    """Check whether the terminal can reliably render Braille glyphs.

    Returns
    -------
    bool
        True if the locale's preferred encoding is UTF-8 and the terminal
        is not the raw Linux virtual console (``TERM=linux``), which usually
        lacks Braille glyphs in its default font even under a UTF-8 locale.
    """
    # TERM=linux is the raw Linux virtual console: even under a UTF-8 locale
    # its default font usually lacks Braille glyphs, so always fall back there.
    if os.environ.get("TERM") == "linux":
        return False
    return locale.getpreferredencoding().lower().startswith("utf")


UNICODE_OK = supports_unicode()
BAR_FILLED = "⣿" if UNICODE_OK else "#"
BAR_EMPTY = "⠒" if UNICODE_OK else "-"

BOX_H = "─" if UNICODE_OK else "-"
BOX_V = "│" if UNICODE_OK else "|"
BOX_TL = "╭" if UNICODE_OK else "+"
BOX_TR = "╮" if UNICODE_OK else "+"
BOX_BL = "╰" if UNICODE_OK else "+"
BOX_BR = "╯" if UNICODE_OK else "+"

GRAPH_HALF_ROWS = 6
GRAPH_ROWS = GRAPH_HALF_ROWS * 2

STATUS_LINE_RE = re.compile(r"^\s*(\d+\.\d+)\s+\S*-\S*:")
RMS_LEVEL_RE = re.compile(r"lavfi\.astats\.Overall\.RMS_level=(-?[\d.]+|-inf|nan)")

# Per-column Braille dot bitmasks (index = 0..4 dots lit), for the left and
# right dot-columns of one character cell independently. This lets each
# character encode two distinct samples (one per dot-column) rather than
# lighting both together, doubling the graph's horizontal resolution.
# *_BOTTOM fills from the bottom of the cell upward (upper graph half,
# which grows away from the center line, i.e. upward); *_TOP fills from
# the top downward (lower half, which grows away from center downward).
LEFT_DOTS_BOTTOM = (0x00, 0x40, 0x44, 0x46, 0x47)
RIGHT_DOTS_BOTTOM = (0x00, 0x80, 0xA0, 0xB0, 0xB8)
LEFT_DOTS_TOP = (0x00, 0x01, 0x03, 0x07, 0x47)
RIGHT_DOTS_TOP = (0x00, 0x08, 0x18, 0x38, 0xB8)
RMS_HISTORY_LEN = 300
RMS_WINDOW_SECONDS = 0.2
RMS_FLOOR_DB = -40.0
RMS_CEIL_DB = 0.0
RMS_MAX_SCALE = 1.0
RMS_MIN_SCALE = 0.6

LABEL_COL = 16
DATE_COL = 10
DURATION_COL = 8
ARTIST_COL = 20

