def draw_playing(stdscr, item, player, status):  # pylint: disable=too-many-locals,too-many-statements
    """Render the now-playing screen: a centered panel with an RMS volume graph.

    Shows title, artist/date, and source channel in a bordered panel,
    vertically centered in the terminal, above a scrolling RMS volume
    history graph (from `Player.rms_history`; peak growing up from a
    center line in normal brightness, minimum growing down in dim) and a
    single-line info row: a filled progress bar with elapsed/total time
    for items with a known duration (SoundCloud tracks), or just an
    elapsed timer and a "LIVE" marker for live/infinite streams (radio).

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    item : dict
        The now-playing item; needs ``title``, and optionally ``artist``,
        ``date``, ``channel``, ``duration`` (formatted string), and
        ``duration_secs`` (raw seconds, or falsy/absent for live streams).
    player : Player
        The active player, used to read `Player.elapsed` and
        `Player.rms_history`.
    status : str
        Status/hint text for the bottom bar.
    """
    stdscr.erase()
    height, width = stdscr.getmaxyx()

    artist = item.get("artist", "")
    date = item.get("date", "")
    channel = item.get("channel", "")
    subtitle = f"{artist}  ·  {date}" if artist else date

    body_lines = [(item["title"], curses.A_BOLD)]
    if subtitle:
        body_lines.append((subtitle, curses.A_NORMAL))
    if channel:
        body_lines.append((f"— {channel} —", curses.A_DIM))

    panel_width = min(max(width - 4, 20), max(width - 2, 1))
    content_width = max(panel_width - 4, 1)
    panel_height = min(2 + len(body_lines) + 1 + GRAPH_ROWS + 1, max(height - 1, 3))

    panel_x = max((width - panel_width) // 2, 0)
    panel_y = max((height - 1 - panel_height) // 2, 0)

    draw_panel_border(stdscr, panel_y, panel_x, panel_height, panel_width)
    draw_top_right(stdscr, 0, width, APP_BRAND)

    row = panel_y + 1
    last_row = panel_y + panel_height - 1
    for text, attr in body_lines:
        if row >= last_row:
            break
        stdscr.addnstr(row, panel_x + 2, center_text(text, content_width), content_width, attr)
        row += 1
    row += 1  # blank separator before the volume graph

    for graph_row in rms_graph_rows(player.rms_history, GRAPH_HALF_ROWS, content_width):
        if row >= last_row:
            break
        draw_graph_row(stdscr, row, panel_x + 2, graph_row, width)
        row += 1

    elapsed_str = format_duration(player.elapsed)
    duration_secs = item.get("duration_secs")

    if duration_secs:
        suffix = item["duration"]
        bar_width = max(content_width - len(elapsed_str) - len(suffix) - 2, 1)
        filled = int(min(player.elapsed / duration_secs, 1.0) * bar_width)
        progress_str = BAR_FILLED * filled + BAR_EMPTY * (bar_width - filled)
    else:
        suffix = "LIVE"
        bar_width = max(content_width - len(elapsed_str) - 6, 1)
        progress_str = " " * bar_width

    bar_x = panel_x + 2 + len(elapsed_str) + 1
    suffix_x = bar_x + bar_width + 1

    if row < last_row:
        draw_bar_segment(stdscr, row, bar_x, progress_str, width)
        if panel_x + 2 < width:
            stdscr.addnstr(row, panel_x + 2, elapsed_str, max(min(len(elapsed_str), width - (panel_x + 2)), 0))
        if suffix_x < width:
            stdscr.addnstr(row, suffix_x, suffix, max(min(len(suffix), width - suffix_x), 0))

    draw_status_bar(stdscr, height - 1, width, status)
    stdscr.refresh()


def track_hint(count, continuous):
    """Build the status/hint line for the track-list screen.

    Parameters
    ----------
    count : int
        Number of tracks in the list.
    continuous : bool
        Current continuous-play toggle state, shown as ON/OFF.

    Returns
    -------
    str
        The formatted hint line.
    """
    state = "ON" if continuous else "OFF"
    return f"{count} tracks | j/k move, gg/G top/bottom, Enter play, c continuous:{state}, r refresh, b back, q quit"


def playing_hint(continuous, back_view):
    """Build the status/hint line for the now-playing screen.

    Parameters
    ----------
    continuous : bool
        Current continuous-play toggle state, shown as ON/OFF.
    back_view : str
        The view to return to on ``b``/stop (``"stations"`` or
        ``"tracks"``); the continuous-play hint is only shown when this is
        ``"tracks"``, since it doesn't apply to live radio.

    Returns
    -------
    str
        The formatted hint line.
    """
    if back_view == "tracks":
        state = "ON" if continuous else "OFF"
        return f"b back, x stop, continuous:{state}, q quit"
    return "b back, x stop, q quit"


@dataclass
class AppState:  # pylint: disable=too-many-instance-attributes
    """Shared mutable state for the stations/tracks/playing view loop.

    Attributes
    ----------
    stations : list of dict
        All configured stations, loaded once at startup.
    view : str
        Current screen: ``"stations"``, ``"tracks"``, or ``"playing"``.
    station_selected : int
        Index of the highlighted station in the stations screen.
    station_top : int
        Scroll offset for the stations screen.
    station_status : str
        Status/hint text for the stations screen.
    tracks : list of dict
        Tracks fetched for the currently browsed SoundCloud station.
    current_station : dict or None
        The SoundCloud station `tracks` belongs to, so ``r`` can re-fetch
        and re-cache the right one from the tracks screen.
    track_selected : int
        Index of the highlighted track in the tracks screen.
    track_top : int
        Scroll offset for the tracks screen.
    track_status : str
        Status/hint text for the tracks screen.
    now_playing : dict or None
        The item currently loaded in the player, or None.
    playing_status : str
        Status/hint text for the playing screen.
    back_view : str
        View to return to from the playing screen (``"stations"`` or
        ``"tracks"``), set when playback starts.
    pending_g : bool
        True after a single ``g`` keypress, awaiting a second ``g`` to
        complete the vim-style ``gg`` (jump to top) sequence.
    continuous : bool
        Whether finished tracks should auto-advance to the next one.
    """

    stations: list
    view: str = "stations"
    station_selected: int = 0
    station_top: int = 0
    station_status: str = ""

    tracks: list = field(default_factory=list)
    current_station: dict | None = None
    track_selected: int = 0
    track_top: int = 0
    track_status: str = ""

    now_playing: dict | None = None
    playing_status: str = ""
    back_view: str = "stations"
    pending_g: bool = False
    continuous: bool = False

    def __post_init__(self):
        """Fill in `station_status` now that `stations` is known."""
        self.station_status = (
            f"{len(self.stations)} stations | j/k move, gg/G top/bottom, " "Enter select, v now-playing, q quit"
        )


def select_station(stdscr, state, player, limit):
    """Handle Enter on the stations screen: load tracks or play live radio.

    If the selected station is a SoundCloud URL, loads its tracks from the
    on-disk cache when one exists — yt-dlp fetches are slow and sometimes
    fail outright, so normal navigation never re-fetches over the network.
    Only a first-ever visit (no cache yet) fetches fresh; press ``r`` on
    the tracks screen to force a refresh later. Otherwise, starts playing
    the station directly as a live stream and switches to ``"playing"``.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into while fetching (shows a status message).
    state : AppState
        Mutable app state; updated in place.
    player : Player
        The active player, used to start live-radio playback.
    limit : int
        Max number of tracks to fetch, passed through to `fetch_tracks`.
    """
    station = state.stations[state.station_selected]
    if is_soundcloud_url(station["url"]):
        cached = load_cached_tracks(station)
        if cached is not None:
            state.tracks = cached
            state.current_station = station
            state.track_selected = 0
            state.track_top = 0
            state.track_status = track_hint(len(state.tracks), state.continuous)
            state.view = "tracks"
            return
        state.station_status = f"Fetching tracks: {station['label']}..."
        draw_stations(stdscr, state.stations, state.station_selected, state.station_top, state.station_status)
        try:
            state.tracks = fetch_and_cache_tracks(station, limit)
            state.current_station = station
            state.track_selected = 0
            state.track_top = 0
            state.track_status = track_hint(len(state.tracks), state.continuous)
            state.view = "tracks"
        except subprocess.CalledProcessError as exc:
            state.station_status = f"Failed to fetch tracks: {exc.stderr}"
    else:
        player.play(station["url"], station["label"])
        state.now_playing = {
            "title": station["label"],
            "date": "",
            "duration": "",
            "duration_secs": None,
        }
        state.playing_status = "b back, x stop, q quit"
        state.back_view = "stations"
        state.view = "playing"


def handle_stations_view(stdscr, state, player, limit):
    """Draw the stations screen and handle one keypress on it.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    state : AppState
        Mutable app state; updated in place based on the key pressed.
    player : Player
        The active player, used for the ``v``/``x`` keys.
    limit : int
        Max tracks to fetch if a SoundCloud station is selected, passed
        through to `select_station`.

    Returns
    -------
    bool
        False if ``q`` was pressed (caller should quit the app), True
        otherwise (keep running).
    """
    stdscr.timeout(-1)
    state.station_top = draw_stations(
        stdscr, state.stations, state.station_selected, state.station_top, state.station_status
    )
    key = stdscr.getch()

    if key in (ord("j"), curses.KEY_DOWN):
        state.station_selected = min(state.station_selected + 1, len(state.stations) - 1)
        state.pending_g = False
    elif key in (ord("k"), curses.KEY_UP):
        state.station_selected = max(state.station_selected - 1, 0)
        state.pending_g = False
    elif key == ord("g"):
        state.station_selected = 0 if state.pending_g else state.station_selected
        state.pending_g = not state.pending_g
    elif key == ord("G"):
        state.station_selected = len(state.stations) - 1
        state.pending_g = False
    elif key in (curses.KEY_ENTER, 10, 13):
        state.pending_g = False
        select_station(stdscr, state, player, limit)
    elif key == ord("v") and player.is_playing():
        state.pending_g = False
        state.playing_status = playing_hint(state.continuous, state.back_view)
        state.view = "playing"
    elif key == ord("x"):
        state.pending_g = False
        player.stop()
        state.station_status = "Stopped"
    elif key == ord("q"):
        return False
    else:
        state.pending_g = False
    return True


def play_track(stdscr, state, player, track):
    """Download and start playing a track selected from the tracks screen.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into while downloading (shows a status message).
    state : AppState
        Mutable app state; updated in place.
    player : Player
        The active player, used to start playback.
    track : dict
        The track to play, as returned by `fetch_tracks`.
    """
    state.track_status = f"Downloading: {track['title']}"
    draw_tracks(stdscr, state.tracks, state.track_selected, state.track_top, state.track_status)
    try:
        temp_path = prepare_track(track)
        player.play(temp_path, track["title"], temp_path=temp_path)
        state.now_playing = track
        state.playing_status = playing_hint(state.continuous, "tracks")
        state.back_view = "tracks"
        state.view = "playing"
    except subprocess.CalledProcessError, OSError:
        state.track_status = f"Failed to download: {track['title']}"


def refresh_tracks(stdscr, state, limit):
    """Handle ``r`` on the tracks screen: force a fresh fetch and re-cache.

    Unlike `select_station`, this always hits the network — it's the only
    way to pick up new uploads or recover from a stale/corrupt cache.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into while fetching (shows a status message).
    state : AppState
        Mutable app state; updated in place. Uses `state.current_station`
        set by `select_station`; does nothing if that's unset.
    limit : int
        Max number of tracks to fetch, passed through to `fetch_tracks`.
    """
    station = state.current_station
    if station is None:
        return
    state.track_status = f"Refreshing tracks: {station['label']}..."
    draw_tracks(stdscr, state.tracks, state.track_selected, state.track_top, state.track_status)
    try:
        state.tracks = fetch_and_cache_tracks(station, limit)
        state.track_selected = 0
        state.track_top = 0
        state.track_status = track_hint(len(state.tracks), state.continuous)
    except subprocess.CalledProcessError as exc:
        state.track_status = f"Failed to refresh tracks: {exc.stderr}"


def handle_tracks_view(stdscr, state, player, limit):
    """Draw the tracks screen and handle one keypress on it.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    state : AppState
        Mutable app state; updated in place based on the key pressed.
    player : Player
        The active player, used for the ``v``/``x`` keys.
    limit : int
        Max number of tracks to fetch, passed through to `refresh_tracks`.

    Returns
    -------
    bool
        False if ``q`` was pressed (caller should quit the app), True
        otherwise (keep running).
    """
    stdscr.timeout(-1)
    state.track_top = draw_tracks(stdscr, state.tracks, state.track_selected, state.track_top, state.track_status)
    key = stdscr.getch()

    if key in (ord("j"), curses.KEY_DOWN):
        state.track_selected = min(state.track_selected + 1, len(state.tracks) - 1)
        state.pending_g = False
    elif key in (ord("k"), curses.KEY_UP):
        state.track_selected = max(state.track_selected - 1, 0)
        state.pending_g = False
    elif key == ord("g"):
        state.track_selected = 0 if state.pending_g else state.track_selected
        state.pending_g = not state.pending_g
    elif key == ord("G"):
        state.track_selected = len(state.tracks) - 1
        state.pending_g = False
    elif key in (curses.KEY_ENTER, 10, 13):
        state.pending_g = False
        play_track(stdscr, state, player, state.tracks[state.track_selected])
    elif key == ord("c"):
        state.pending_g = False
        state.continuous = not state.continuous
        state.track_status = track_hint(len(state.tracks), state.continuous)
    elif key == ord("r"):
        state.pending_g = False
        refresh_tracks(stdscr, state, limit)
    elif key == ord("v") and player.is_playing():
        state.pending_g = False
        state.playing_status = playing_hint(state.continuous, state.back_view)
        state.view = "playing"
    elif key == ord("x"):
        state.pending_g = False
        player.stop()
        state.track_status = "Stopped"
    elif key in (ord("b"), 27):
        state.pending_g = False
        state.view = "stations"
    elif key == ord("q"):
        return False
    else:
        state.pending_g = False
    return True


def advance_or_finish(stdscr, state, player):
    """Handle a track finishing: auto-advance if continuous play is on.

    Called from `handle_playing_view` once `player.is_playing()` goes
    False. If continuous play is enabled, we're playing from a track list,
    and a next track exists, downloads and plays it. Otherwise, marks
    playback as finished.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into while downloading the next track.
    state : AppState
        Mutable app state; updated in place.
    player : Player
        The active player, used to start the next track.
    """
    can_advance = state.continuous and state.back_view == "tracks" and state.track_selected + 1 < len(state.tracks)
    if not can_advance:
        state.playing_status = f"Finished | {playing_hint(state.continuous, state.back_view)}"
        return

    state.track_selected += 1
    next_track = state.tracks[state.track_selected]
    state.playing_status = f"Downloading: {next_track['title']}"
    draw_playing(stdscr, state.now_playing, player, state.playing_status)
    try:
        temp_path = prepare_track(next_track)
        player.play(temp_path, next_track["title"], temp_path=temp_path)
        state.now_playing = next_track
        state.playing_status = playing_hint(state.continuous, state.back_view)
    except subprocess.CalledProcessError, OSError:
        state.track_status = f"Failed to download: {next_track['title']}"
        state.now_playing = None
        state.view = "tracks"


def handle_playing_view(stdscr, state, player):
    """Draw the now-playing screen and handle one keypress on it.

    Also checks whether playback has finished (polled every 200ms) and
    delegates to `advance_or_finish` if so.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    state : AppState
        Mutable app state; updated in place based on the key pressed.
    player : Player
        The active player.

    Returns
    -------
    bool
        False if ``q`` was pressed (caller should quit the app), True
        otherwise (keep running).
    """
    stdscr.timeout(200)
    if not player.is_playing() and state.now_playing is not None:
        advance_or_finish(stdscr, state, player)

    if state.view != "playing":
        return True

    draw_playing(stdscr, state.now_playing, player, state.playing_status)
    key = stdscr.getch()

    if key in (ord("b"), 27, curses.KEY_ENTER, 10, 13):
        state.view = state.back_view
    elif key == ord("x"):
        player.stop()
        state.view = state.back_view
    elif key == ord("c") and state.back_view == "tracks":
        state.continuous = not state.continuous
        state.playing_status = playing_hint(state.continuous, state.back_view)
    elif key == ord("q"):
        return False
    return True


def run_view(stdscr, state, player, limit):
    """Dispatch to the handler for the current view.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    state : AppState
        Mutable app state; `state.view` selects which handler runs.
    player : Player
        The active player, passed through to the handler.
    limit : int
        Max tracks to fetch, passed through to `handle_stations_view` and
        `handle_tracks_view`.

    Returns
    -------
    bool
        False if the app should quit, True to keep running.
    """
    if state.view == "stations":
        return handle_stations_view(stdscr, state, player, limit)
    if state.view == "tracks":
        return handle_tracks_view(stdscr, state, player, limit)
    return handle_playing_view(stdscr, state, player)


def main(stdscr, config_path, limit):
    """Run the app's main event loop.

    Loads the station config, then repeatedly dispatches to the current
    view's handler via `run_view` until the user quits.

    Parameters
    ----------
    stdscr : curses window
        The root window, provided by `curses.wrapper`.
    config_path : pathlib.Path
        Path to the ``stations.toml`` file to load.
    limit : int
        Max number of tracks to fetch per SoundCloud station.

    Raises
    ------
    ConfigError
        If the config file is missing, empty, or fails to parse.
    """
    curses.curs_set(0)
    stdscr.keypad(True)

    try:
        stations = load_stations(config_path)
    except FileNotFoundError:
        raise ConfigError(f"No stations file found at {config_path}\n\n{STATIONS_EXAMPLE}") from None
    except (OSError, ValueError, tomllib.TOMLDecodeError) as exc:
        raise ConfigError(f"Failed to load {config_path}: {exc}\n\n{STATIONS_EXAMPLE}") from None

    if not stations:
        raise ConfigError(f"No stations defined in {config_path}\n\n{STATIONS_EXAMPLE}")

    state = AppState(stations)
    player = Player()

    try:
        while run_view(stdscr, state, player, limit):
            pass
    finally:
        player.stop()


if __name__ == "__main__":
    locale.setlocale(locale.LC_ALL, "")  # let ncursesw render multi-byte UTF-8 correctly

    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if not DEFAULT_CONFIG.exists() and BUNDLED_CONFIG.exists():
        shutil.copy(BUNDLED_CONFIG, DEFAULT_CONFIG)

    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--config",
        type=Path,
        default=DEFAULT_CONFIG,
        help=f"Path to stations TOML file (default: {DEFAULT_CONFIG})",
    )
    parser.add_argument(
        "--limit",
        type=int,
        default=50,
        help="Number of most recent tracks to fetch per SoundCloud station (default: 50)",
    )
    args = parser.parse_args()

    for tool in ("yt-dlp", "ffplay"):
        if shutil.which(tool) is None:
            print(f"Required tool not found: {tool}", file=sys.stderr)
            sys.exit(1)

    try:
        curses.wrapper(main, args.config, args.limit)
    except ConfigError as exc:
        print(exc, file=sys.stderr)
        sys.exit(1)
