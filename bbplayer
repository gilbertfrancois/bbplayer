class ConfigError(Exception):
    """Raised when the stations config file is missing, empty, or invalid."""


def load_stations(path):
    """Load and validate the station list from a TOML config file.

    Parameters
    ----------
    path : pathlib.Path or str
        Path to the ``stations.toml`` file.

    Returns
    -------
    list of dict
        Each dict has at least ``label`` and ``url`` keys, in file order.

    Raises
    ------
    OSError
        If the file cannot be opened.
    tomllib.TOMLDecodeError
        If the file is not valid TOML.
    ValueError
        If a ``[[station]]`` entry is missing ``label`` or ``url``.
    """
    with open(path, "rb") as f:
        data = tomllib.load(f)
    stations = data.get("station", [])
    for entry in stations:
        if "label" not in entry or "url" not in entry:
            raise ValueError(f"station entry missing 'label' or 'url': {entry}")
    return stations


def is_soundcloud_url(url):
    """Check whether a station URL points at SoundCloud.

    Parameters
    ----------
    url : str
        The station's configured URL.

    Returns
    -------
    bool
        True if the URL's host is SoundCloud.
    """
    return "soundcloud.com" in url.lower()


def format_date(upload_date):
    """Format a yt-dlp ``upload_date`` string as ``YYYY-MM-DD``.

    Parameters
    ----------
    upload_date : str or None
        An 8-character date string in ``YYYYMMDD`` form, as returned by
        yt-dlp, or None/empty if unknown.

    Returns
    -------
    str
        The formatted date, or ``"----------"`` if `upload_date` is
        missing or not 8 characters long.
    """
    if not upload_date or len(upload_date) != 8:
        return "----------"
    return f"{upload_date[:4]}-{upload_date[4:6]}-{upload_date[6:]}"


def format_duration(seconds):
    """Format a duration in seconds as ``M:SS`` or ``H:MM:SS``.

    Parameters
    ----------
    seconds : float, int, or None
        Duration in seconds, or None if unknown.

    Returns
    -------
    str
        ``"--:--"`` if `seconds` is None, ``"M:SS"`` for durations under an
        hour, or ``"H:MM:SS"`` otherwise.
    """
    if seconds is None:
        return "--:--"
    seconds = int(seconds)
    hours, seconds = divmod(seconds, 3600)
    minutes, seconds = divmod(seconds, 60)
    if hours:
        return f"{hours}:{minutes:02d}:{seconds:02d}"
    return f"{minutes}:{seconds:02d}"


def parse_rms_db(text):
    """Convert an astats ``RMS_level`` string to a floor-clamped dB value.

    Parameters
    ----------
    text : str
        The raw value matched by `RMS_LEVEL_RE`: a decimal string, or
        ``"-inf"``/``"nan"`` during silence.

    Returns
    -------
    float
        The level in dBFS, clamped to `RMS_FLOOR_DB` at the low end.
    """
    if text in ("-inf", "nan"):
        return RMS_FLOOR_DB
    return max(float(text), RMS_FLOOR_DB)


def fetch_tracks(channel_url, limit):
    """Fetch metadata for the most recent tracks on a SoundCloud channel.

    Parameters
    ----------
    channel_url : str
        URL of the SoundCloud channel's tracks (or playlist) page.
    limit : int
        Maximum number of most recent tracks to fetch. Full (non-flat)
        yt-dlp extraction is used to get duration/date, which is slow per
        track, so this caps how many network requests are made.

    Returns
    -------
    list of dict
        Track dicts with ``title``, ``artist``, ``url``, ``timestamp``,
        ``date``, ``duration`` (formatted string), and ``duration_secs``
        (raw seconds, or None if unknown), sorted newest first.

    Raises
    ------
    subprocess.CalledProcessError
        If yt-dlp fails (network error, invalid channel, etc.).
    """
    proc = subprocess.run(
        ["yt-dlp", "-j", "--playlist-end", str(limit), channel_url],
        capture_output=True,
        text=True,
        check=True,
    )
    tracks = []
    for line in proc.stdout.splitlines():
        if not line.strip():
            continue
        data = json.loads(line)
        tracks.append(
            {
                "title": data.get("title") or "(untitled)",
                "artist": data.get("artist") or data.get("uploader") or "(unknown artist)",
                "url": data["webpage_url"],
                "timestamp": data.get("timestamp") or 0,
                "date": format_date(data.get("upload_date")),
                "duration": format_duration(data.get("duration")),
                "duration_secs": data.get("duration"),
            }
        )
    tracks.sort(key=lambda t: t["timestamp"], reverse=True)
    return tracks


def cache_path_for_station(station):
    """Compute the on-disk cache file for a SoundCloud station's track list.

    Parameters
    ----------
    station : dict
        Station dict with a ``url`` key.

    Returns
    -------
    pathlib.Path
        A path under `CACHE_DIR`, named from a hash of the station's URL
        (so it survives label renames and needs no filename sanitizing).
    """
    digest = hashlib.sha256(station["url"].encode("utf-8")).hexdigest()[:16]
    return CACHE_DIR / f"{digest}.json"


def load_cached_tracks(station):
    """Load a station's previously cached track list, if any.

    Parameters
    ----------
    station : dict
        Station dict with a ``url`` key.

    Returns
    -------
    list of dict or None
        The cached tracks, or None if there's no cache yet or it can't be
        read (missing, corrupt, or otherwise invalid).
    """
    try:
        with open(cache_path_for_station(station), "r", encoding="utf-8") as f:
            return json.load(f)
    except OSError, ValueError:
        return None


def save_cached_tracks(station, tracks):
    """Save a station's track list to disk, best-effort.

    Failures are silent: the cache is a convenience (it saves a slow,
    sometimes-flaky yt-dlp fetch on the next visit), not something
    playback should ever depend on.

    Parameters
    ----------
    station : dict
        Station dict with a ``url`` key.
    tracks : list of dict
        Tracks as returned by `fetch_tracks`, to persist verbatim.
    """
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        with open(cache_path_for_station(station), "w", encoding="utf-8") as f:
            json.dump(tracks, f)
    except OSError:
        pass


def fetch_and_cache_tracks(station, limit):
    """Fetch a station's tracks over the network, tag them, and cache them.

    Parameters
    ----------
    station : dict
        Station dict with ``url`` and ``label`` keys.
    limit : int
        Max number of tracks to fetch, passed through to `fetch_tracks`.

    Returns
    -------
    list of dict
        The fetched tracks, each tagged with ``channel`` set to the
        station's label.

    Raises
    ------
    subprocess.CalledProcessError
        If yt-dlp fails (network error, invalid channel, etc.).
    """
    tracks = fetch_tracks(station["url"], limit)
    for track in tracks:
        track["channel"] = station["label"]
    save_cached_tracks(station, tracks)
    return tracks


def resolve_stream_url(track_url):
    """Resolve a SoundCloud track page URL to a direct audio stream URL.

    Prefers a progressive (non-HLS) format: SoundCloud's HLS streams make
    ffplay fetch a new segment every few seconds, which causes audible
    stutter/silence at segment boundaries. A plain http stream avoids that.

    Parameters
    ----------
    track_url : str
        URL of the SoundCloud track's webpage.

    Returns
    -------
    str
        Direct, signed URL to the audio stream.

    Raises
    ------
    subprocess.CalledProcessError
        If yt-dlp fails to resolve the URL.
    """
    proc = subprocess.run(
        ["yt-dlp", "-f", "bestaudio[protocol=http]/bestaudio", "-g", track_url],
        capture_output=True,
        text=True,
        check=True,
    )
    return proc.stdout.strip().splitlines()[0]


def download_track(url, dest_path):
    """Download a track to a local file, verifying it isn't truncated.

    SoundCloud tracks are small (a few MB); downloading up front avoids
    ffplay's real-time HTTP stream getting cut off mid-track by the CDN.
    The CDN has occasionally served a short read on a cold cache entry, so
    the download is verified against ``Content-Length`` rather than trusted
    blindly.

    Parameters
    ----------
    url : str
        Direct stream URL, as returned by `resolve_stream_url`.
    dest_path : str or pathlib.Path
        Local file path to write the download to.

    Raises
    ------
    OSError
        If the download is shorter than the server's advertised
        ``Content-Length`` (the partial file is removed before raising).
    """
    with urllib.request.urlopen(url) as response:
        expected = response.length
        with open(dest_path, "wb") as out:
            shutil.copyfileobj(response, out)

    actual = os.path.getsize(dest_path)
    if expected is not None and actual != expected:
        os.remove(dest_path)
        raise OSError(f"incomplete download: got {actual} of {expected} bytes")


def prepare_track(track, attempts=3):
    """Resolve and download a track to a temp file, retrying on failure.

    The CDN occasionally serves a short read on a cold cache entry (caught
    by the ``Content-Length`` check in `download_track`); this retries a
    few times against the same resolved URL before giving up.

    Parameters
    ----------
    track : dict
        Track dict as returned by `fetch_tracks`; only ``url`` is used.
    attempts : int, optional
        Number of download attempts before giving up (default 3).

    Returns
    -------
    str
        Path to the downloaded temp file (caller is responsible for
        deleting it; see `Player.stop`).

    Raises
    ------
    subprocess.CalledProcessError
        If yt-dlp fails to resolve the stream URL.
    OSError
        If all download attempts result in an incomplete file.
    """
    stream_url = resolve_stream_url(track["url"])
    last_error = None
    for _ in range(attempts):
        fd, temp_path = tempfile.mkstemp(suffix=".mp3", prefix="bbplayer_")
        os.close(fd)
        try:
            download_track(stream_url, temp_path)
            return temp_path
        except OSError as exc:
            if os.path.exists(temp_path):
                os.remove(temp_path)
            last_error = exc
    raise last_error


class Player:  # pylint: disable=too-many-instance-attributes
    """Manage a background ``ffplay`` process and track its playback position.

    Attributes
    ----------
    proc : subprocess.Popen or None
        The running ffplay process, or None if nothing is playing.
    title : str or None
        Title of the currently playing item.
    elapsed : float
        Seconds into the current stream, parsed live from ffplay's stderr
        status line.
    rms_history : collections.deque of (float, float)
        Recent ``(min_db, peak_db)`` RMS volume readings (oldest first),
        each aggregated over `RMS_WINDOW_SECONDS` of ffplay's
        `astats`/`ametadata` audio filter output.
    temp_path : str or None
        Path to a downloaded temp file to delete on `stop`, if any.
    """

    def __init__(self):
        """Create a Player with nothing loaded or playing."""
        self.proc = None
        self.title = None
        self.elapsed = 0.0
        self.rms_history = deque(maxlen=RMS_HISTORY_LEN)
        self._rms_window = []
        self._rms_window_start = None
        self._reader_thread = None
        self.temp_path = None

    def play(self, stream_url, title, temp_path=None):
        """Stop any current playback and start playing a new stream.

        Parameters
        ----------
        stream_url : str
            URL or local file path for ffplay to play.
        title : str
            Display title for the now-playing screen.
        temp_path : str or None, optional
            Path to a downloaded temp file that should be deleted once
            playback stops (see `stop`). None for live/streamed URLs that
            aren't backed by a temp file.
        """
        self.stop()
        # No -loglevel quiet: ffplay's stderr status line ("12.34 M-A: ...")
        # is how we read live playback position without a real IPC channel.
        # The astats/ametadata filter chain likewise prints an RMS volume
        # reading to stderr for every audio frame, for the volume graph.
        # Process outlives this method (managed via stop()/is_playing()), so
        # a `with` block here would kill it as soon as play() returns.
        self.proc = subprocess.Popen(  # pylint: disable=consider-using-with
            [
                "ffplay",
                "-nodisp",
                "-autoexit",
                "-af",
                "astats=metadata=1:reset=1,ametadata=print:key=lavfi.astats.Overall.RMS_level",
                stream_url,
            ],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
        )
        self.title = title
        self.elapsed = 0.0
        self.rms_history.clear()
        self._rms_window = []
        self._rms_window_start = None
        self.temp_path = temp_path
        self._reader_thread = threading.Thread(target=self._read_progress, daemon=True)
        self._reader_thread.start()

    def _read_progress(self):
        """Continuously parse ffplay's stderr for playback position and volume.

        Runs in a background thread started by `play`; updates
        `self.elapsed` on every status line, and collects RMS readings into
        `self._rms_window`, flushing a ``(min_db, peak_db)`` pair to
        `self.rms_history` every `RMS_WINDOW_SECONDS`. Returns when
        ffplay's stderr closes (process exited).
        """
        proc = self.proc
        try:
            for line in proc.stderr:
                status_match = STATUS_LINE_RE.match(line)
                if status_match:
                    self.elapsed = float(status_match.group(1))
                    continue
                rms_match = RMS_LEVEL_RE.search(line)
                if rms_match:
                    self._collect_rms(parse_rms_db(rms_match.group(1)))
        except ValueError, OSError:
            pass

    def _collect_rms(self, db):
        """Add one RMS reading to the current window, flushing it if due.

        Parameters
        ----------
        db : float
            A single RMS reading in dBFS, already floor-clamped.
        """
        now = time.time()
        if self._rms_window_start is None:
            self._rms_window_start = now
        self._rms_window.append(db)
        if now - self._rms_window_start >= RMS_WINDOW_SECONDS:
            minimum = min(self._rms_window)
            peak = max(self._rms_window)
            self.rms_history.append((minimum, peak))
            self._rms_window = []
            self._rms_window_start = now

    def stop(self):
        """Terminate any running ffplay process and clean up its temp file."""
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()
        self.proc = None
        self.title = None
        self.elapsed = 0.0
        self.rms_history.clear()
        self._rms_window = []
        self._rms_window_start = None
        if self.temp_path:
            try:
                os.remove(self.temp_path)
            except OSError:
                pass
            self.temp_path = None

    def is_playing(self):
        """Check whether ffplay is currently running.

        Returns
        -------
        bool
            True if a playback process is running.
        """
        return self.proc is not None and self.proc.poll() is None


def _db_to_dots(db, max_dots):
    """Normalize a dB level to a 0..`max_dots` fill amount.

    Parameters
    ----------
    db : float
        Level in dBFS.
    max_dots : int
        Number of sub-row dots available (one half's row count times the
        Braille sub-row resolution, or 1 per row without Braille support).

    Returns
    -------
    int
        Fill amount, clamped to ``[0, max_dots]``.
    """
    value = (db - RMS_FLOOR_DB) / (RMS_CEIL_DB - RMS_FLOOR_DB)
    return max(0, min(round(value * max_dots), max_dots))


def _braille_char(left_n, right_n, grow_from_top):
    """Combine independent left/right dot-column fill levels into one glyph.

    Parameters
    ----------
    left_n, right_n : int
        Number of dots lit in each column, 0..4.
    grow_from_top : bool
        False to fill from the bottom of the cell upward (the graph's
        upper half, which grows away from the center line, i.e. upward);
        True to fill from the top downward (the lower half, which grows
        away from center downward).

    Returns
    -------
    str
        A single Braille character, or a blank space if both are 0.
    """
    left_bits = LEFT_DOTS_TOP if grow_from_top else LEFT_DOTS_BOTTOM
    right_bits = RIGHT_DOTS_TOP if grow_from_top else RIGHT_DOTS_BOTTOM
    bits = left_bits[left_n] | right_bits[right_n]
    return chr(0x2800 + bits) if bits else " "


def rms_graph_rows(history, half_rows, width):  # pylint: disable=too-many-locals
    """Render a scrolling, vertically mirrored bar graph of RMS volume.

    The upper half shows the peak level growing upward from a center
    line, rendered normal-brightness; the lower half shows the minimum
    level growing downward, rendered dim — an asymmetric mirror, rather
    than combining both values into each half. Using a flat attribute per
    half (rather than a gradient by row) keeps the two halves visually
    distinct right up to the center line, instead of both fading to the
    same shade and blurring into a gray band there. When Braille is
    available, each character's left and right dot-columns are driven by
    two independent, consecutive history samples (oldest on the left),
    doubling horizontal resolution so a single loud sample shows as a
    1-dot-wide spike rather than 2 dots wide.

    Parameters
    ----------
    history : sequence of (float, float)
        Recent ``(min_db, peak_db)`` windows (oldest first, most recent
        last), as collected by `Player._read_progress`.
    half_rows : int
        Number of terminal rows per half (the graph is `2 * half_rows`
        rows tall in total).
    width : int
        Number of columns to display.

    Returns
    -------
    list of list of (str, int)
        `2 * half_rows` rows, each a list of `width` ``(char, attr)``
        cells.
    """
    total_rows = half_rows * 2
    rows = [[(" ", curses.A_DIM) for _ in range(width)] for _ in range(total_rows)]
    if width <= 0 or half_rows <= 0:
        return rows

    sub_levels = 4 if UNICODE_OK else 1
    max_dots = half_rows * sub_levels
    samples_per_col = 2 if UNICODE_OK else 1

    needed = width * samples_per_col
    samples = list(history)[-needed:]
    samples = [(RMS_FLOOR_DB, RMS_FLOOR_DB)] * (needed - len(samples)) + samples

    for col in range(width):
        left_min_db, left_peak_db = samples[col * samples_per_col]
        right_min_db, right_peak_db = samples[col * samples_per_col + samples_per_col - 1]

        left_peak_dots = round(_db_to_dots(left_peak_db, max_dots) * RMS_MAX_SCALE)
        right_peak_dots = round(_db_to_dots(right_peak_db, max_dots) * RMS_MAX_SCALE)
        left_min_dots = round(_db_to_dots(left_min_db, max_dots) * RMS_MIN_SCALE)
        right_min_dots = round(_db_to_dots(right_min_db, max_dots) * RMS_MIN_SCALE)

        for half_row in range(half_rows):
            dist = half_rows - 1 - half_row

            peak_left_n = max(0, min(left_peak_dots - dist * sub_levels, sub_levels))
            peak_right_n = max(0, min(right_peak_dots - dist * sub_levels, sub_levels))
            if peak_left_n or peak_right_n:
                char = _braille_char(peak_left_n, peak_right_n, grow_from_top=False) if UNICODE_OK else "#"
                rows[half_row][col] = (char, curses.A_NORMAL)

            min_left_n = max(0, min(left_min_dots - dist * sub_levels, sub_levels))
            min_right_n = max(0, min(right_min_dots - dist * sub_levels, sub_levels))
            if min_left_n or min_right_n:
                char = _braille_char(min_left_n, min_right_n, grow_from_top=True) if UNICODE_OK else "#"
                rows[total_rows - 1 - half_row][col] = (char, curses.A_DIM)

    return rows


def draw_bar_segment(stdscr, y, x, bar_str, screen_width):
    """Draw a bar string, dimming background cells and brightening active ones.

    `bar_str` is drawn in runs of consecutive identical characters so that
    active cells (anything but ``BAR_EMPTY`` or blank space) render brighter
    (bold) than background cells (dim), without relying on terminal color
    support. Clipped to `screen_width` so an oversized bar can't write past
    the edge of the terminal.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    y, x : int
        Starting row/column for the bar.
    bar_str : str
        The bar contents (e.g. as produced by a progress fill).
    screen_width : int
        Total terminal width; `bar_str` is truncated so it never extends
        past column ``screen_width - 1``.
    """
    bar_str = bar_str[: max(screen_width - x, 0)]
    col = x
    i = 0
    while i < len(bar_str):
        j = i
        while j < len(bar_str) and bar_str[j] == bar_str[i]:
            j += 1
        attr = curses.A_DIM if bar_str[i] in (BAR_EMPTY, " ") else curses.A_BOLD
        stdscr.addnstr(y, col, bar_str[i:j], j - i, attr)
        col += j - i
        i = j


def draw_graph_row(stdscr, y, x, cells, screen_width):
    """Draw one row of `(char, attr)` cells, as produced by `rms_graph_rows`.

    Consecutive cells with an identical `(char, attr)` pair are drawn in a
    single run for efficiency. Clipped to `screen_width` so an oversized
    row can't write past the edge of the terminal.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    y, x : int
        Starting row/column for the row.
    cells : list of (str, int)
        One `(character, curses attribute)` pair per column.
    screen_width : int
        Total terminal width; `cells` is truncated so it never extends
        past column ``screen_width - 1``.
    """
    cells = cells[: max(screen_width - x, 0)]
    col = x
    i = 0
    while i < len(cells):
        j = i
        while j < len(cells) and cells[j] == cells[i]:
            j += 1
        char, attr = cells[i]
        run_len = j - i
        stdscr.addnstr(y, col, char * run_len, run_len, attr)
        col += run_len
        i = j


def format_row(col1, col2, col3, title, width):
    """Format a fixed-width ``DATE  LENGTH  ARTIST  TITLE``-style table row.

    Parameters
    ----------
    col1 : str
        Text for the first (date-width) column.
    col2 : str
        Text for the second (duration-width) column.
    col3 : str
        Text for the third (artist-width) column; truncated to fit.
    title : str
        Text for the remaining space; truncated to fit `width`.
    width : int
        Total terminal width available for the row.

    Returns
    -------
    str
        The formatted row.
    """
    title_width = max(width - DATE_COL - DURATION_COL - ARTIST_COL - 3, 0)
    return f"{col1:<{DATE_COL}} {col2:<{DURATION_COL}} " f"{col3[:ARTIST_COL]:<{ARTIST_COL}} {title[:title_width]}"


def draw_status_bar(stdscr, y, width, status):
    """Draw a left-aligned status/hint line, never truncating it for brand text.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    y : int
        Row to draw on.
    width : int
        Terminal width, used to avoid writing past the last column.
    status : str
        Status/hint text to display.
    """
    avail = max(width - 1, 0)
    stdscr.addnstr(y, 0, status[:avail], avail, curses.A_BOLD)


def draw_top_right(stdscr, y, width, text, existing_len=0):
    """Draw dimmed text right-aligned on a row, if there's room for it.

    Decorative brand text: only drawn if there's a gap to the right of the
    existing row content; never truncates that content to make room.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    y : int
        Row to draw on.
    width : int
        Terminal width, used to compute the right-aligned column.
    text : str
        Text to draw (e.g. `APP_BRAND`).
    existing_len : int, optional
        Length of content already drawn on this row starting at column 0;
        `text` is skipped entirely if it would overlap that content.
    """
    avail = max(width - 1, 0)
    x = avail - len(text)
    if x > existing_len:
        stdscr.addnstr(y, x, text, avail - x, curses.A_DIM)


def center_text(text, width):
    """Pad `text` with spaces on both sides to center it within `width`.

    Parameters
    ----------
    text : str
        Text to center; truncated if longer than `width`.
    width : int
        Field width to center within.

    Returns
    -------
    str
        The centered, space-padded string, exactly `width` characters long.
    """
    text = text[:width]
    pad = width - len(text)
    left = pad // 2
    return " " * left + text + " " * (pad - left)


def draw_panel_border(stdscr, y, x, height, width):
    """Draw a rounded-corner box border.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    y, x : int
        Top-left corner of the border.
    height, width : int
        Outer size of the box, including the border itself.
    """
    stdscr.addnstr(y, x, BOX_TL + BOX_H * (width - 2) + BOX_TR, width)
    for row in range(1, height - 1):
        stdscr.addnstr(y + row, x, BOX_V, 1)
        stdscr.addnstr(y + row, x + width - 1, BOX_V, 1)
    stdscr.addnstr(y + height - 1, x, BOX_BL + BOX_H * (width - 2) + BOX_BR, width)


def draw_stations(stdscr, stations, selected, top, status):  # pylint: disable=too-many-locals
    """Render the station-list screen: a bordered pane with a header and a
    scrollable list, in the same style as the now-playing panel.

    The pane shrinks to fit and centers vertically when the station list
    is short, or grows to fill the available height (scrolling) when it
    isn't — the same sizing behavior as the now-playing panel. The
    brand/version stays top-right of row 0, above the pane, and the
    status/hint bar stays on the last row, below it — both in the same
    position as on the now-playing screen.

    Parameters
    ----------
    stdscr : curses window
        Window to draw into.
    stations : list of dict
        Station dicts with ``label`` and ``url`` keys.
    selected : int
        Index of the currently highlighted station.
    top : int
        Index of the first visible row (for scrolling); may be adjusted
        to keep `selected` in view.
    status : str
        Status/hint text for the bottom bar.

    Returns
    -------
    int
        The (possibly adjusted) scroll offset; pass this back in as `top`
        on the next call.
    """
    stdscr.erase()
    height, width = stdscr.getmaxyx()

    panel_width = min(max(width - 4, 20), max(width - 2, 1))
    content_width = max(panel_width - 4, 1)
    panel_x = max((width - panel_width) // 2, 0)
    desired_height = 2 + 1 + len(stations)
    if height >= 4:
        # Row 0 (brand) and the last row (status bar) are always kept free.
        usable_height = max(height - 2, 1)
        panel_height = min(desired_height, usable_height)
        panel_y = 1 + max((usable_height - panel_height) // 2, 0)
    else:
        panel_y = 0
        panel_height = max(height - 1, 1)

    draw_panel_border(stdscr, panel_y, panel_x, panel_height, panel_width)
    draw_top_right(stdscr, 0, width, APP_BRAND)

    list_height = max(panel_height - 3, 0)
    if selected < top:
        top = selected
    elif selected >= top + list_height:
        top = selected - list_height + 1

    header = f"{'KIND':<{LABEL_COL}} LABEL".ljust(content_width)
    if panel_y + 1 < height:
        stdscr.addnstr(panel_y + 1, panel_x + 2, header[:content_width], content_width, curses.A_UNDERLINE)

    for row in range(list_height):
        idx = top + row
        if idx >= len(stations):
            break
        station = stations[idx]
        kind = "soundcloud" if is_soundcloud_url(station["url"]) else "radio"
        line = f"{kind:<{LABEL_COL}} {station['label']}"
        attr = curses.A_REVERSE if idx == selected else curses.A_NORMAL
        stdscr.addnstr(panel_y + 2 + row, panel_x + 2, line[:content_width], content_width, attr)

    draw_status_bar(stdscr, height - 1, width, status)
    stdscr.refresh()
    return top


